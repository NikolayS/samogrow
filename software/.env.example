# samogrow secrets — copy to .env and fill in. Never commit the real .env.

# Telegram bot token from @BotFather
SAMOGROW_TELEGRAM_TOKEN=

# Your Telegram numeric user id (the bot only obeys this chat)
SAMOGROW_TELEGRAM_CHAT_ID=

# Anthropic API key for the vision brain
ANTHROPIC_API_KEY=

# Set to 1 to force mock mode (no hardware) — handy on a Mac
# SAMOGROW_MOCK=1
